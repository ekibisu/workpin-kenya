          "label": "What service do you need?",
          "placeholder": "e.g. I need a 60-minute deep tissue massage at home",
          "required": true
        },
        {
          "id": "extent_people",
          "pillar": "Extent",
          "type": "select",
          "label": "How many people is this for?",
          "options": ["Just me", "2 people", "3–5 people", "A group (6+)"],
          "required": true
        },
        {
          "id": "extent_frequency",
          "pillar": "Extent",
          "type": "select",
          "label": "Is this a one-time or recurring need?",
          "options": ["One time", "Weekly", "Bi-weekly", "Monthly"],
          "required": true
        },
        {
          "id": "deadline",
          "pillar": "Deadline",
          "type": "select",
          "label": "When do you want this?",
          "options": ["Today", "Tomorrow", "This week", "This month", "I'm flexible"],
          "required": true
        },
        {
          "id": "location_preference",
          "pillar": "Task",
          "type": "select",
          "label": "Where should the service happen?",
          "options": ["At my home", "At a salon / studio", "At my office", "Provider decides"],
          "required": true
        }
      ]
    },

    "events_celebrations": {
      "label": "Events & Celebrations",
      "icon": "party-popper",
