        },
        {
          "id": "extent_scope",
          "pillar": "Extent",
          "type": "select",
          "label": "How large is the scope of work?",
          "options": ["Small task (under 2 hours)", "Half-day project", "Full-day project", "Ongoing / retainer"],
          "required": true
        },
        {
          "id": "deadline",
          "pillar": "Deadline",
          "type": "select",
          "label": "When do you need this completed?",
          "options": ["ASAP", "Within 3 days", "This week", "This month", "I'm flexible"],
          "required": true
        },
        {
          "id": "remote_or_onsite",
          "pillar": "Task",
          "type": "select",
          "label": "Can this be done remotely?",
          "options": ["Yes, fully remote", "Needs to be on-site", "Either works"],
          "required": true
        }
      ]
    },

    "outdoor_heavy_duty": {
      "label": "Outdoor & Heavy Duty",
      "icon": "hammer",
      "color": "#2E7D32",
      "questions": [
        {
          "id": "task_description",
          "pillar": "Task",
          "type": "textarea",
          "label": "Describe the job",
