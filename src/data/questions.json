{
  "archetypes": {
    "home_maintenance": {
      "label": "Home Maintenance",
      "icon": "home",
      "color": "#1565C0",
      "questions": [
        {
          "id": "task_description",
          "pillar": "Task",
          "type": "textarea",
          "label": "Describe the problem",
          "placeholder": "e.g. My kitchen tap is leaking and the water pressure is low",
          "required": true
        },
        {
          "id": "property_type",
          "pillar": "Task",
          "type": "select",
          "label": "Property type",
          "options": ["Apartment", "House", "Office", "Shop / Commercial", "Other"],
          "required": true
        },
        {
          "id": "extent_rooms",
          "pillar": "Extent",
          "type": "select",
          "label": "How many rooms / units are affected?",
          "options": ["Just one", "2–3 rooms", "4–5 rooms", "Whole house / building"],
          "required": true
        },
        {
          "id": "extent_severity",
          "pillar": "Extent",
          "type": "select",
          "label": "How urgent is this?",
          "options": ["It's an emergency", "Needs fixing soon", "Not urgent, just planning"],
          "required": true
        },
        {
          "id": "deadline",
          "pillar": "Deadline",
          "type": "select",
          "label": "When do you need this done?",
          "options": ["Today", "Within 2 days", "This week", "This month", "I'm flexible"],
          "required": true
        },
        {
          "id": "images",
          "pillar": "Extent",
          "type": "image_upload",
          "label": "Add photos (optional)",
          "placeholder": "Photos help providers give accurate quotes",
          "required": false,
          "max_files": 3
        }
      ]
    },

    "lifestyle_wellness": {
      "label": "Lifestyle & Wellness",
      "icon": "heart",
      "color": "#AD1457",
      "questions": [
        {
          "id": "task_description",
          "pillar": "Task",
