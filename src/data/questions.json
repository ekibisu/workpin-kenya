        {
          "id": "extent_complexity",
          "pillar": "Extent",
          "type": "select",
          "label": "How complex is the job?",
          "options": ["Straightforward", "Some complexity", "Highly complex / specialist required"],
          "required": true
        },
        {
          "id": "materials",
          "pillar": "Extent",
          "type": "select",
          "label": "Who supplies materials?",
          "options": ["Provider supplies everything", "I supply materials", "We can discuss"],
          "required": true
        },
        {
          "id": "deadline",
          "pillar": "Deadline",
          "type": "select",
          "label": "When should this start?",
          "options": ["Immediately", "Within a week", "Within a month", "I'm still planning"],
          "required": true
        },
        {
          "id": "images",
          "pillar": "Task",
          "type": "image_upload",
          "label": "Photos of the site (optional but recommended)",
          "required": false,
          "max_files": 4
        }
      ]
    }
