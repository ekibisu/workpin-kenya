        {
          "id": "extent_guests",
          "pillar": "Extent",
          "type": "select",
          "label": "How many guests?",
          "options": ["Under 20", "20–50", "50–100", "100–200", "200+"],
          "required": true
        },
        {
          "id": "extent_duration",
          "pillar": "Extent",
          "type": "select",
          "label": "How long is the event?",
          "options": ["Under 2 hours", "Half day (2–5 hrs)", "Full day", "Multi-day"],
          "required": true
        },
        {
          "id": "deadline",
          "pillar": "Deadline",
          "type": "date",
          "label": "Event date",
          "required": true
        },
        {
          "id": "images",
          "pillar": "Task",
          "type": "image_upload",
          "label": "Inspiration photos (optional)",
          "required": false,
          "max_files": 4
        }
      ]
    },

    "professional_business": {
      "label": "Professional & Business",
      "icon": "briefcase",
      "color": "#1A3A5C",
      "questions": [
        {
          "id": "task_description",
          "pillar": "Task",
